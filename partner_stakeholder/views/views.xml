<odoo>
  <data>
    
    <record model='ir.ui.view' id="stakeholder_list">
        <field name="name">res.partner.stakeholder.list</field>
        <field name="model">res.partner.stakeholder</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="res_model" invisible="1" force_save="1" />
                <field name='partner_id' />
                <field name="tag_ids" widget="many2many_tags" />
            </tree>
        </field>    
    </record>
      
    <record model="ir.ui.view" id="stakeholder_partner_form">
      <field name="name">stakeholder.partner.form</field>
      <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />    
        <field name="arch" type="xml">
          <xpath expr="(//notebook/page)[last()]" position="after">
              <page string="Stakeholder">
                  <group>
                  <group>
                  <div
                  colspan="4"
                >Elenco degli stakeholder di QUESTO partner</div>
                  <field
                  nolabel="1"
                  name="ref_stakeholder_ids"
                  context="{'default_res_model': 'res.partner'}"
                >
                  </field>    
                  </group>
                  <group>    
                  <div
                  colspan="4"
                >Elenco delle entità COLLEGATE al partner</div>
                  <field nolabel="1" name="stakeholder_ids" readonly="1">
                      <tree>
                          <field name="res_model_label" readonly="1" />
                          <field name="name" />
                          <button
                      name="action_open_related_record"
                      type="object"
                      icon='fa-external-link'
                      class="oe_stat_button float-left"
                      string=" "
                    />
                          <field name="tag_ids" widget="many2many_tags" />
                      </tree>    
                  </field>
                      </group>    
                  </group>    
              </page>    
          </xpath>    
      </field>
    </record>

    <record model="ir.ui.view" id="stakeholder_lead_form">
        <field name="name">stakeholder_lead_form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="arch" type="xml">
          <xpath expr="(//notebook/page)[last()]" position="after">
              <page string="Stakeholder">
                  <field
              name="ref_stakeholder_ids"
              context="{'default_res_model': 'crm.lead'}"
            >
                  </field>    
              </page>    
            </xpath>    
        </field>    
    </record>      

    <record model="ir.ui.view" id="stakeholder_project_form">
        <field name="name">stakeholder_project_form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
          <xpath expr="(//notebook/page)[last()]" position="after">
              <page string="Stakeholder">
                  <field
              name="ref_stakeholder_ids"
              context="{'default_res_model': 'project.project'}"
            >
                  </field>    
              </page>    
            </xpath>    
        </field>    
    </record>      

    <record model="ir.ui.view" id="stakeholder_task_form">
        <field name="name">stakeholder_task_form</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2" />
        <field name="arch" type="xml">
          <xpath expr="(//notebook/page)[last()]" position="after">
              <page string="Stakeholder">
                  <field
              name="ref_stakeholder_ids"
              context="{'default_res_model': 'project.task'}"
            >
                  </field>    
              </page>    
            </xpath>    
        </field>    
    </record>      
      
      
  </data>
</odoo>
