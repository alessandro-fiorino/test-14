<odoo>
  <data>

    <record model="ir.ui.view" id="msa_helpdesk_ticket_list">
      <field name="name">msa_helpdesk ticket list</field>
      <field name="model">helpdesk.ticket</field>
	  <field name="inherit_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
      <field name="arch" type="xml">
	<xpath expr="//tree" position="attributes">
	   <attribute name="default_order">create_date desc</attribute>
	</xpath>
  <xpath expr="//field[@name='display_name']" position="after">
    <field name="create_date"/>
    <field name="close_date" optional="hide"/>	  
  </xpath>
  
      </field>
    </record>
	  
    <record model="ir.ui.view" id="msa_helpdesk_ticket_form">
      <field name="name">msa_helpdesk ticket form</field>
      <field name="model">helpdesk.ticket</field>
	  <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
      <field name="arch" type="xml">
	<xpath expr="//field[@name='email_cc']" position="attributes">
	   <attribute name="groups"></attribute>
	</xpath>
          <xpath expr="//field[@name='user_id']" position="before">
              <field name="member_ids" invisible="1"/>
          </xpath>
          <xpath expr="//field[@name='user_id']" position="attributes">
              <attribute name="domain">[('id','in',member_ids)]</attribute>
          </xpath>    
          <xpath expr="//field[@name='ticket_type_id']" position="attributes">
              <attribute name="domain">['|',('team_id','=',False),('team_id','=',team_id)]</attribute>
          </xpath>    
          <xpath expr="//field[@name='tag_ids']" position="attributes">
              <attribute name="domain">['|',('team_id','=',False),('team_id','=',team_id)]</attribute>
          </xpath>    
      </field>
    </record>	  

    <record model="ir.ui.view" id="msa_helpdesk_stage_list">
      <field name="name">msa_helpdesk stage list</field>
      <field name="model">helpdesk.stage</field>
	  <field name="inherit_id" ref="helpdesk.helpdesk_stage_view_tree"/>
      <field name="arch" type="xml">
	<xpath expr="//field[@name='name']" position="after">
	   <field name="team_ids" widget="many2many_tags"/>
	</xpath>
      </field>
    </record>	  

    <record model="ir.ui.view" id="msa_helpdesk_tag_list">
      <field name="name">msa_helpdesk tag list</field>
      <field name="model">helpdesk.tag</field>
	  <field name="inherit_id" ref="helpdesk.helpdesk_tag_view_tree"/>
      <field name="arch" type="xml">
	<xpath expr="//field[@name='name']" position="after">
           <field name="color"/>
	   <field name="team_id"/>
	</xpath>
      </field>
    </record>	  

    <record model="ir.ui.view" id="msa_helpdesk_ticket_type_list">
      <field name="name">msa_helpdesk ticket type list</field>
      <field name="model">helpdesk.ticket.type</field>
	  <field name="inherit_id" ref="helpdesk.helpdesk_ticket_type_view_tree"/>
      <field name="arch" type="xml">
	<xpath expr="//field[@name='name']" position="after">
	   <field name="team_id"/>
	</xpath>
      </field>
    </record>	         
      
    <record model="ir.ui.view" id="msa_helpdesk_team_form">
      <field name="name">helpdesk team form</field>
      <field name="model">helpdesk.team</field>
	  <field name="inherit_id" ref="helpdesk.helpdesk_team_view_form"/>
      <field name="arch" type="xml">
	<xpath expr="//field[@name='company_id']" position="after">
        <br/><label for="check_tags"/>
	   <field name="check_tags"/>
	</xpath>
      </field>
    </record>	         
      
  </data>
</odoo>
